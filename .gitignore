# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
report.html
assets/

# ---- Node ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
frontend/dist/
frontend/.vite/

# ---- Build output ----
dist/
build/
*.tsbuildinfo

# ---- Environments ----
# Ignore real env files but keep the committed templates (.env.example and the
# frontend/.env placeholder).
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
!.env.example
!**/.env.example
!frontend/.env

# ---- IDE / OS ----
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store

# ---- Deploy ----
.vercel/

# ---- Runtime data (never commit user or control-plane data) ----
# User workspaces: code, provisioned SQLite files, and the control-plane
# metadata DB all live here. Only the placeholder is tracked.
workspaces/
!workspaces/.gitkeep
.cloud_ide/
*.db-wal
*.db-shm

# ---- Misc ----
*.log
logs/
*.tar
*.pid

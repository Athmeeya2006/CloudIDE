# ---- Core ----
WORKSPACE_BASE=/workspaces
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://cloud-ide-ebon.vercel.app
MAX_PROCESSES=10
PORT=8000

# ---- Auth ----
# Secret used to sign session tokens. Set a long random value in production so
# tokens survive restarts. If empty, a random per-process secret is used.
AUTH_SECRET=

# ---- Run / preview ----
# Prefer production build-and-serve over heavy dev servers. Auto-enabled on
# hosts with under ~1 GiB RAM; set true to force it on.
LOW_MEMORY=false
# Extra ports the preview must never treat as a user app (comma-separated). The
# IDE's own backend port is always excluded automatically.
RESERVED_PORTS=

# ---- Per-project databases (shared servers) ----
# Leave the *_HOST values empty to disable that engine. When set, the IDE
# creates one logical database per project on these shared servers.
MAX_DATABASES_PER_USER=20

PG_HOST=
PG_PORT=5432
PG_ADMIN_USER=ide_admin
PG_ADMIN_PASSWORD=ide_admin_pw

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=ide_admin_pw

MONGO_HOST=
MONGO_PORT=27017
MONGO_ADMIN_USER=ide_admin
MONGO_ADMIN_PASSWORD=ide_admin_pw

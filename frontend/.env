# Leave these EMPTY to talk to the backend on the SAME ORIGIN as the page.
# That works everywhere: local dev (Vite proxies /api -> :8000), Docker
# (nginx proxies /api -> backend:8000), and remote access (server IP/domain).
#
# Only set them to an absolute URL for a SPLIT deployment where the frontend
# and backend live on different domains, e.g.:
#   VITE_API_URL=https://api.example.com
#   VITE_WS_URL=wss://api.example.com
VITE_API_URL=
VITE_WS_URL=
